# Thickness Agent — headless configuration (no browser needed).
#
# Copy this to  /etc/thickness-agent/agent.env  on the customer machine, fill in
# the values from the customer's Activation Card, then:
#     sudo systemctl restart thickness-agent
#
# The agent validates DEVICE_ID + DEVICE_KEY against the server on startup,
# pulls the customer name + sensor mode automatically, and begins uploading.
# This is the easiest way to pre-configure a Raspberry Pi before shipping it.

# --- Required: the customer's Activation Card -------------------------------
DEVICE_ID=dev_xxxxxxxx
DEVICE_KEY=replace-with-the-secret-from-provision

# --- Sensors: LABEL=IP[:PORT], comma-separated (port defaults to 8234) ------
#   opposite mode = 2 sensors (A,B)   |   sbs mode = 3 sensors (A,B,C)
SENSORS=A=192.168.1.200,B=192.168.1.201

# --- Cloud server URL -------------------------------------------------------
# Default (normal networks):   https://194-164-148-145.sslip.io
# Use the HTTP/IP form ONLY where sslip.io DNS is intercepted on the sensor LAN:
SERVER_URL=http://194.164.148.145:8082

# --- Optional knobs ---------------------------------------------------------
# WIZARD_HOST=0.0.0.0     # reach the setup wizard from another PC (headless Pi)
# POST_RATE_HZ=5          # upload rate
# SIMULATE=1             # synthetic readings — prove the pipeline with no sensors
