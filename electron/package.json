{
  "name": "thickness-monitor-electron",
  "version": "1.0.0",
  "description": "Desktop shell for Merged Thickness Monitor",
  "main": "main.mjs",
  "type": "module",
  "author": "Rajdeep Analytics",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "./node_modules/electron/dist/electron .",
    "dev": "NODE_ENV=development ./node_modules/electron/dist/electron .",
    "build:rpi32": "npx electron-builder --linux --armv7l",
    "build:rpi64": "npx electron-builder --linux --arm64"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.rajdeep.thickness-monitor",
    "productName": "Thickness Monitor",
    "directories": { "output": "dist" },
    "files": [ "main.mjs", "preload.js", "offline.html" ],
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["armv7l", "arm64"] },
        { "target": "deb", "arch": ["armhf", "arm64"] }
      ],
      "category": "Utility"
    }
  }
}